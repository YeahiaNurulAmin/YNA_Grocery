{
    "version": 2,
    "builds": [
        {
            "src": "server.js",
            "use": "@vercel/node",
            "config": {
                "includeFiles": [
                    "dist/**"
                ]
            }
        }
    ],
    "routes": [
        {
            "src": "/api/(.*)",
            "methods": ["OPTIONS"],
            "headers": {
                "Access-Control-Allow-Origin": "https://yna-grocery-liart.vercel.app",
                "Access-Control-Allow-Methods": "GET, POST, PUT, DELETE, PATCH, OPTIONS",
                "Access-Control-Allow-Headers": "Content-Type, Authorization",
                "Access-Control-Allow-Credentials": "true",
                "Access-Control-Max-Age": "86400"
            },
            "status": 204
        },
        {
            "src": "/(.*)",
            "headers": {
                "Access-Control-Allow-Origin": "https://yna-grocery-liart.vercel.app",
                "Access-Control-Allow-Credentials": "true"
            },
            "dest": "server.js"
        }
    ]
}